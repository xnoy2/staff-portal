APP_NAME="Staff Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Development: http://127.0.0.1:8000  |  Production: https://yourdomain.up.railway.app
APP_URL=https://yourdomain.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Railway injects these automatically when you add a MySQL service.
# Copy the values from the Railway dashboard Variables tab.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
# Railway has no persistent local disk — avatars go in storage/ which must be
# backed by a Railway Volume mounted at /app/storage.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 for file storage (profile avatars, etc.)
# Get credentials from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=staffportal
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# After enabling public access on the bucket, set this to the public URL
# e.g. https://pub-xxxx.r2.dev  OR  https://your-custom-domain.com
CLOUDFLARE_R2_PUBLIC_URL=

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
